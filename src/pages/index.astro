---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import '../stylesheets/style.css';
---

<Layout>
    <div class="container">
        <Header/>
          <div class="nameboard" style="display:flex">
            <span id="name">Matic Jurač</span><span id="alias">a.k.a. mjura</span>
          </div>
        <div class="about">
            <p>
                Undergraduate Computer Engineering student. Focused on Machine Learning, DevOps and System Software. Intern at <a target="_blank" href="https://troia.eu/">Troia</a>.
            </p>
            <p>
                I primarily work in Python, C/C++ and C#.  
            </p>
        </div>
        <div class="projects">
            <h3>Projects</h3>
            <p>wip</p>
        </div>
        <div class="education">
            <h3>Education</h3>
            <ul>
                <li>University of Maribor - Maribor, Slovenia (2023-Present)
                    <ul>
                        <li>Undergraduate degree in Computer Engineering</li>                    
                    </ul>
                </li>
                <li>
                    Ravne High School - Ravne na Koroškem, Slovenia (2020 - 2023)
                    <ul>
                        <li>
                            High school diploma
                        </li>
                        <li>Golden Graduate</li>
                    </ul>
                </li>
                <li>
                    High School of Chemistry, Electrotechnics and Computer Science - Celje, Slovenia (2019 - 2020)
                </li>
            </ul>
        </div>
        <div class="contact">
            <h3>Contact & links</h3>
            <ul class="links">
                <li>
                    <a 
                    href="mailto:bWF0aWMuZGV2ZWxvcGVyQHByb3Rvbi5tZQ"
                    onclick="this.href='mailto:'+atob('bWF0aWMuZGV2ZWxvcGVyQHByb3Rvbi5tZQ'); setTimeout(() => this.href='mailto:bWF0aWMuZGV2ZWxvcGVyQHByb3Rvbi5tZQ', 200);return true;">
                        E-Mail
                    </a>
                </li>
                <li>
                    <a href="https://github.com/mjura1" target="_blank">GitHub</a>
                </li>
            </ul>
        </div>
    </div>
</Layout>

<style>
  .container {
    max-width: 40vw;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    vertical-align: middle;
    text-align: left;
    text-shadow: 0.5rem;
    font-size: 1rem;
}

.nameboard {
  padding: 5rem 0 0 0;
  display:flex;
  align-items: flex-end;
}

#name {
  font-size: 1.1rem;
  margin-right: 1.5rem;
  line-height: 1;
}

#alias {
  color: grey;
  font-style: italic;
  font-size: 0.9rem;
  padding-bottom: 0;
  margin-bottom: 0;
}

.links {
    list-style-type: none;
    padding-left: 0;
}

.links > li {
    display: inline-block;
    margin-right: 1rem;
}
  
</style>
